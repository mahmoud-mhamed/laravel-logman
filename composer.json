{
    "name": "mahmoud-mhamed/laravel-logman",
    "description": "Automatic error reporting and log management for Laravel applications",
    "keywords": ["laravel", "logging", "errors", "exceptions", "monitoring"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/log": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "MahmoudMhamed\\Logman\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MahmoudMhamed\\Logman\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MahmoudMhamed\\Logman\\LogmanServiceProvider"
            ],
            "aliases": {
                "Logman": "MahmoudMhamed\\Logman\\Facades\\Logman"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
