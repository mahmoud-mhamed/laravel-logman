{
    "name": "mhamed/laravel-logman",
    "description": "Automatic error reporting and log management for Laravel applications",
    "keywords": ["laravel", "logging", "errors", "exceptions", "monitoring"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/log": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mhamed\\Logman\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mhamed\\Logman\\LogmanServiceProvider"
            ],
            "aliases": {
                "Logman": "Mhamed\\Logman\\Facades\\Logman"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
